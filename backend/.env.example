# Kazify Backend Environment Configuration

# Server running configurations
PORT=5000
NODE_ENV=development

# PostgreSQL Connection String (Prisma format)
# Update this with your database user, password, host, port, and database name.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kazify?schema=public"

# Authentication Security Settings
# If BYPASS_FIREBASE_AUTH is set to "true", the server will verify headers containing "x-bypass-firebase-id" 
# instead of calling the live Firebase SDK endpoints, enabling easy local development and automated routing tests.
BYPASS_FIREBASE_AUTH=true

# Path to the Google/Firebase Service Account JSON credential file.
# Required if BYPASS_FIREBASE_AUTH is false or unset.
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# Stripe Escrow Integration Details
# Required for real transaction processing. If blank or in development, simulated flow fallback triggers.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
